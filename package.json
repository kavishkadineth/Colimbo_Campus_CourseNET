{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "dev:frontend": "npm run dev --prefix frontend",
        "dev:admin": "npm run dev --prefix adminpanel",
        "build:frontend": "npm run build --prefix frontend",
        "build:admin": "npm run build --prefix adminpanel",
        "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\" \"npm run dev:admin\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "axios": "^1.18.0",
        "bootstrap": "^5.3.8",
        "chart.js": "^4.5.1",
        "react-chartjs-2": "^5.3.1"
    }
}
